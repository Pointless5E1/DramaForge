# ==================== 數據庫配置 ====================
# 數據庫文件路徑（可選）
# 默認路徑: backend/novelforge.db
# 可以指定絕對路徑來自定義數據庫位置
# NOVELFORGE_DB_PATH=/path/to/your/database.db
# 兼容舊變量：AIAUTHOR_DB_PATH

# 知識圖譜 Provider（優先）
KNOWLEDGE_GRAPH_PROVIDER=sqlite

NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

ASSISTANT_USE_LANGCHAIN=1

#模型調用失敗時最大重試次數
MAX_TOOL_CALL_RETRIES=5

# 控制是否在啓動時覆蓋已有的內置數據（知識庫/提示詞等）
BOOTSTRAP_OVERWRITE=true
# 控制卡片schema是否覆蓋，默認爲false，設置爲true時會重置已有的內置卡片schema
BOOTSTRAP_OVERWRITE_CARD_SCHEMAS=false

# ==================== 工作流配置 ====================
# 持久化運行記錄保留時間（天），默認 7
WORKFLOW_RETENTION_PERSISTENT_DAYS=7

